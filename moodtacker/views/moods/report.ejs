<%- include('../partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-header">
  <div>
    <h1 class="page-title">📊 MIS Decision Report</h1>
    <p class="page-subtitle">Emotion trends and support escalation analysis</p>
  </div>
  <a href="/moods" class="btn btn-ghost">← Back to History</a>
</div>

<!-- ── Decision 2: Support Escalation Alerts ──────────────────────────────── -->
<% if (escalationAlerts.length > 0) { %>
  <section class="report-section">
    <h2 class="section-title critical-title">🚨 Support Escalation Alerts</h2>
    <p class="section-desc">Children with 2 or more high-intensity (≥7) episodes in the past 7 days:</p>
    <div class="escalation-grid">
      <% escalationAlerts.forEach(a => { %>
        <div class="escalation-card">
          <div class="esc-child">👦 <%= a.childName %></div>
          <div class="esc-count"><%= a.count %> high-intensity episodes</div>
          <div class="esc-action">⚡ Recommend immediate caregiver review</div>
        </div>
      <% }) %>
    </div>
  </section>
<% } else { %>
  <div class="alert alert-success">✅ No escalation alerts — no children flagged for high-intensity recurring distress this week.</div>
<% } %>

<!-- ── Summary Stats ──────────────────────────────────────────────────────── -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= totalEntries %></div>
    <div class="stat-label">Total Entries</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= emotionStats.length %></div>
    <div class="stat-label">Unique Emotions</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= recentHighIntensity.length %></div>
    <div class="stat-label">High-Intensity (Last 7 Days)</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= escalationAlerts.length %></div>
    <div class="stat-label">Escalation Alerts</div>
  </div>
</div>

<!-- ── Decision 1: Report Generation — Charts ────────────────────────────── -->
<section class="report-section">
  <h2 class="section-title">📈 Emotion Frequency & Average Intensity</h2>
  <div class="chart-grid">
    <div class="chart-box">
      <h3>Emotion Frequency</h3>
      <canvas id="freqChart"></canvas>
    </div>
    <div class="chart-box">
      <h3>Average Intensity by Emotion</h3>
      <canvas id="intensityChart"></canvas>
    </div>
  </div>
</section>

<!-- ── Emotion Stats Table ────────────────────────────────────────────────── -->
<section class="report-section">
  <h2 class="section-title">📋 Detailed Emotion Breakdown</h2>
  <% if (emotionStats.length === 0) { %>
    <p class="empty-text">No data available yet. Start logging moods.</p>
  <% } else { %>
    <table class="report-table">
      <thead>
        <tr>
          <th>Emotion</th>
          <th>Occurrences</th>
          <th>Avg. Intensity</th>
          <th>Intensity Level</th>
        </tr>
      </thead>
      <tbody>
        <% emotionStats.forEach(stat => { %>
          <%
            const avg = parseFloat(stat.avgIntensity);
            let badge = 'badge-low';
            let label = 'Low';
            if (avg >= 7) { badge = 'badge-critical'; label = 'High'; }
            else if (avg >= 5) { badge = 'badge-warning'; label = 'Moderate'; }
          %>
          <tr>
            <td><strong><%= stat.emotion %></strong></td>
            <td><%= stat.count %></td>
            <td><%= stat.avgIntensity %></td>
            <td><span class="badge <%= badge %>"><%= label %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<!-- ── Recent High-Intensity Entries ─────────────────────────────────────── -->
<% if (recentHighIntensity.length > 0) { %>
  <section class="report-section">
    <h2 class="section-title">⚠️ Recent High-Intensity Episodes (Last 7 Days)</h2>
    <div class="timeline">
      <% recentHighIntensity.forEach(mood => { %>
        <div class="timeline-card intensity-critical">
          <div class="card-left">
            <div class="emotion-badge"><%= mood.emotion %></div>
            <span class="intensity-label">Intensity: <strong><%= mood.intensity %>/10</strong></span>
          </div>
          <div class="card-body">
            <div class="card-child">👦 <%= mood.childName %></div>
            <% if (mood.triggerDescription) { %>
              <p class="card-trigger">💬 "<%= mood.triggerDescription %>"</p>
            <% } %>
            <div class="card-meta">
              <span>🕐 <%= new Date(mood.occurredAt).toLocaleString() %></span>
              <span>📝 <%= mood.recordedBy %></span>
            </div>
          </div>
          <div class="card-actions">
            <a href="/moods/<%= mood._id %>" class="btn btn-xs btn-ghost">View</a>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<script>
  const chartData = <%- chartData %>;

  const colors = [
    '#6366f1','#f59e0b','#10b981','#ef4444','#3b82f6',
    '#ec4899','#14b8a6','#f97316','#8b5cf6','#06b6d4'
  ];

  // Frequency Bar Chart
  new Chart(document.getElementById('freqChart'), {
    type: 'bar',
    data: {
      labels: chartData.labels,
      datasets: [{
        label: 'Times Recorded',
        data: chartData.counts,
        backgroundColor: colors.slice(0, chartData.labels.length),
        borderRadius: 8,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });

  // Avg Intensity Line Chart
  new Chart(document.getElementById('intensityChart'), {
    type: 'line',
    data: {
      labels: chartData.labels,
      datasets: [{
        label: 'Avg Intensity',
        data: chartData.avgIntensities,
        borderColor: '#ef4444',
        backgroundColor: 'rgba(239,68,68,0.1)',
        borderWidth: 2,
        tension: 0.4,
        fill: true,
        pointBackgroundColor: '#ef4444',
        pointRadius: 5
      }]
    },
    options: {
      responsive: true,
      scales: {
        y: { min: 0, max: 10, ticks: { stepSize: 2 } }
      }
    }
  });
</script>

<%- include('../partials/footer') %>
